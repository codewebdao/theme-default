        }

        $field = S_POST('field');
        $value = S_POST('value');
        $posttype_slug = S_POST('type') ?: 'posts';
        $post_lang = S_POST('post_lang') ?: APP_LANG;

        if (empty($field)) {
            echo json_encode(['success' => false, 'message' => __('Field name is required')]);
            return;
        }

        try {
            // Get posttype
            $postModel = new PostsModel($posttype_slug, $post_lang);
            $postType = $postModel->getPostTypeBySlug($posttype_slug);

            if (empty($postType)) {
                echo json_encode(['success' => false, 'message' => __('Post type not found')]);
                return;
            }

            // Decode posttype data
            $postType['fields'] = is_string($postType['fields']) ? json_decode($postType['fields'], true) : $postType['fields'];
            $postType['terms'] = is_string($postType['terms']) ? json_decode($postType['terms'], true) : $postType['terms'];
            $languages = is_string($postType['languages']) ? json_decode($postType['languages'], true) : [];

            // Get next ID
            $currentId = $postType['current_id'] ?? 0;
            $newPostId = $currentId + 1;

            // Default fields only: id, title, slug, status, created_at, updated_at
            $postData = [
                'id' => $newPostId,
                'title' => '',
                'slug' => '',
                'status' => 'draft',
                'created_at' => date('Y-m-d H:i:s'),
                'updated_at' => date('Y-m-d H:i:s'),
            ];

            // Check if field is a default field or custom field
            $defaultFields = ['title', 'slug', 'status'];

            if (in_array($field, $defaultFields)) {
                // Update default field
                $postData[$field] = $value;
            } else {
                // Check if it's a valid custom field from posttype
                $isValidField = false;
                if (!empty($postType['fields'])) {
                    foreach ($postType['fields'] as $customField) {
                        if (isset($customField['field_name']) && $customField['field_name'] === $field) {
                            $isValidField = true;
                            // Add custom field to postData
                            $postData[$field] = $value;
                            break;
                        }
                    }
                }

                if (!$isValidField && !str_starts_with($field, 'terms:')) {
                    echo json_encode(['success' => false, 'message' => __('Invalid field: ') . $field]);
                    return;
                }
            }

            // Auto-generate slug if title is provided
            if (!empty($postData['title']) && empty($postData['slug'])) {
                $postData['slug'] = $this->_slug_unique(
                    url_slug($postData['title']),
                    $posttype_slug,
                    $post_lang
                );
            } elseif (empty($postData['slug'])) {
                // If no title, generate default slug
                $postData['slug'] = $this->_slug_unique(
                    'post-' . $newPostId,
                    $posttype_slug,
                    $post_lang
                );
            }

            // Create post using _add helper
            $result = $this->_add($postType, $postData, $languages, [], $post_lang);

            if ($result) {
                // Get the created post to return full data
                $postsResult = get_posts([
                    'post_type' => $posttype_slug,
                    'lang' => $post_lang,
                    'post__in' => [$newPostId],
                    'posts_per_page' => 1,
                    'post_status' => ''
                ]);

                $createdPost = !empty($postsResult['data']) ? $postsResult['data'][0] : null;

                echo json_encode([
                    'success' => true,
                    'message' => __('Post created successfully'),
                    'data' => $createdPost
                ]);
            } else {
                echo json_encode(['success' => false, 'message' => __('Failed to create post')]);
            }
        } catch (\Exception $e) {
            echo json_encode([
                'success' => false,
                'message' => $e->getMessage()
            ]);
        }
    }
}
