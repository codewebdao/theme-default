    public function getbulkposts()
    {
        header('Content-Type: application/json');

        if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
            echo json_encode(['success' => false, 'message' => __('Invalid request method')]);
            return;
        }

        $postIds = S_POST('post_ids');
        $postIds = array_filter(array_map('intval', explode(',', $postIds)));
        $posttype_slug = S_POST('type') ?: 'posts';
        $post_lang = S_POST('post_lang') ?: APP_LANG;

        if (!is_array($postIds) || empty($postIds)) {
            echo json_encode(['success' => false, 'message' => __('Invalid post selection')]);
            return;
        }

        try {
            // Get posttype to know which terms are available
            $posttype = $this->postsModel->getPostTypeBySlug($posttype_slug);
            $posttype['terms'] = _json_decode($posttype['terms']);

            // Use get_posts helper with terms included
            $postsResult = get_posts([
                'post_type' => $posttype_slug,
                'lang' => $post_lang,
                // 'filters' => [
                //     ['id', $postIds, 'IN']
                // ],
                'post__in' => $postIds,
                'posts_per_page' => -1,
                'post_status' => '',
                'orderby' => 'id',
                'order' => 'ASC',
                'with_terms' => true // Load terms
            ]);

            if (empty($postsResult['data'])) {
                echo json_encode(['success' => false, 'message' => __('No posts found')]);
                return;
            }

            // Format data for spreadsheet (similar to export)
            $posts = [];
            $allTermTypes = [];

            // Collect all term types from posttype
            if (!empty($posttype['terms'])) {
                foreach ($posttype['terms'] as $term) {
                    $allTermTypes[$term['type']] = true;
                }
            }

            foreach ($postsResult['data'] as $post) {
                $item = [];

                // Add ALL fields from post (not just selected ones like export)
                foreach ($post as $fieldName => $value) {
                    // Skip terms array (will be handled separately)
                    if ($fieldName === 'terms') {
                        continue;
                    }

                    // Decode JSON fields for display
                    if (is_string($value) && (substr($value, 0, 1) === '{' || substr($value, 0, 1) === '[')) {
                        $decoded = json_decode($value, true);
                        if (json_last_error() === JSON_ERROR_NONE) {
                            // For arrays/objects, keep as JSON string for spreadsheet
                            $value = is_array($decoded) ? json_encode($decoded) : $value;
                        }
                    }

                    $item[$fieldName] = $value ?? '';
                }

                // Add terms as "terms:type" fields (comma-separated slugs)
                if (!empty($allTermTypes)) {
                    foreach ($allTermTypes as $termType => $v) {
                        $item['terms:' . $termType] = '';
                    }
                }

                if (!empty($post['terms'])) {
                    foreach ($post['terms'] as $term) {
                        $termType = $term['type'];
                        if (isset($item['terms:' . $termType])) {
                            if ($item['terms:' . $termType] !== '') {
                                $item['terms:' . $termType] .= ',' . $term['slug'];
                            } else {
                                $item['terms:' . $termType] = $term['slug'];
                            }
                        } else {
                            $item['terms:' . $termType] = $term['slug'];
                        }
                    }
                }

                $posts[] = $item;
            }

            echo json_encode([
                'success' => true,
                'data' => $posts,
                'term_types' => array_keys($allTermTypes),
                'posttype_fields' => _json_decode($posttype['fields']) // Send field definitions
            ]);
        } catch (\Exception $e) {
            echo json_encode([
                'success' => false,
                'message' => $e->getMessage()
            ]);
        }
    }

    /**
     * Update single field of a post via AJAX
     */
    public function updatebulkpost()
    {
        header('Content-Type: application/json');

        if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
            echo json_encode(['success' => false, 'message' => __('Invalid request method')]);
            return;
        }

        $postId = S_POST('post_id');
        $field = S_POST('field');
        $value = S_POST('value');
        $posttype_slug = S_POST('type') ?: 'posts';
        $post_lang = S_POST('post_lang') ?: APP_LANG;

        if (empty($postId)) {
            echo json_encode(['success' => false, 'message' => __('Post ID is required')]);
            return;
        }

        if (empty($field)) {
            echo json_encode(['success' => false, 'message' => __('Field name is required')]);
            return;
        }

        try {
            // Check if field is a term field (terms:type format)
            $isTermField = strpos($field, 'terms:') === 0;

            if ($isTermField) {
                // Handle term update
                $termType = substr($field, 6); // Remove "terms:" prefix

                // Get current post with terms
                $postsResult = get_posts([
                    'post_type' => $posttype_slug,
                    'lang' => $post_lang,
                    'post__in' => [$postId],
                    'posts_per_page' => 1,
                    'post_status' => '',
                    'with_terms' => true
                ]);

                if (empty($postsResult['data'])) {
                    echo json_encode(['success' => false, 'message' => __('Post not found')]);
                    return;
                }

                $post = $postsResult['data'][0];

                // Get current term IDs for this type
                $currentTermIds = [];
                if (!empty($post['terms'])) {
                    foreach ($post['terms'] as $term) {
                        if ($term['type'] === $termType) {
                            $currentTermIds[] = $term['id'];
                        }
                    }
                }

                // Parse new term slugs from comma-separated string
                $newTermSlugs = array_filter(array_map('trim', explode(',', $value)));
                $newTermIds = [];

                if (!empty($newTermSlugs)) {
                    foreach ($newTermSlugs as $termSlug) {
                        // Get term by slug
                        $term = $this->termsModel->getTermsSlugAndByTypeAndPostTypeAndLang(
                            $termSlug,
                            $posttype_slug,
                            $termType,
                            $post_lang
                        );

                        if ($term) {
                            // Handle both array and single term response
                            if (is_array($term) && isset($term[0])) {
                                $newTermIds[] = $term[0]['id'];
                            } elseif (is_array($term) && isset($term['id'])) {
                                $newTermIds[] = $term['id'];
                            }
                        }
                    }
                }

                // Calculate diff
                $removedTermIds = array_diff($currentTermIds, $newTermIds);
                $addedTermIds = array_diff($newTermIds, $currentTermIds);

                // Add new terms
                foreach ($addedTermIds as $termId) {
                    posts_add_term($postId, $termId, $posttype_slug, $post_lang);
                }

                // Remove old terms
                foreach ($removedTermIds as $termId) {
                    posts_remove_term($postId, $termId, $posttype_slug, $post_lang);
                }

                echo json_encode([
                    'success' => true,
                    'message' => __('Terms updated successfully')
                ]);
            } else {
                // Handle regular field update

                // Get posttype to validate allowed fields
                $posttype = $this->postsModel->getPostTypeBySlug($posttype_slug);
                $posttype['fields'] = _json_decode($posttype['fields']);

                // Build allowed fields list: base fields + posttype custom fields
                // Base fields - always available in any posttype
                $baseEditableFields = ['title', 'slug', 'status', 'created_at', 'updated_at'];

                // Internal fields - should not be editable
                $notAllowedFields = ['id', 'posttype', 'lang'];

                $allowedFields = $baseEditableFields;

                // Add custom fields from posttype definition
                if (!empty($posttype['fields'])) {
                    foreach ($posttype['fields'] as $posttypeField) {
                        $fieldName = $posttypeField['field_name'] ?? '';
                        if (!empty($fieldName) && !in_array($fieldName, $notAllowedFields) && !in_array($fieldName, $allowedFields)) {
                            $allowedFields[] = $fieldName;
                        }
                    }
                }

                // Validate field name
                if (!in_array($field, $allowedFields)) {
                    echo json_encode(['success' => false, 'message' => __('Invalid field name: ') . $field]);
                    return;
                }

                // Get current post
                $postsResult = get_posts([
                    'post_type' => $posttype_slug,
                    'lang' => $post_lang,
                    'post__in' => [$postId],
                    'posts_per_page' => 1,
                    'post_status' => ''
                ]);

                if (empty($postsResult['data'])) {
                    echo json_encode(['success' => false, 'message' => __('Post not found')]);
                    return;
                }

                $post = $postsResult['data'][0];

                // Prepare update data
                $updateData = [$field => $value];

                // If updating title and slug is empty or default, auto-generate slug
                if ($field === 'title') {
                    $newSlug = url_slug($value);
                    if (empty($post['slug']) || $post['slug'] === url_slug($post['title'])) {
                        $updateData['slug'] = $newSlug;
                    }
                }

                // Validate status
                if ($field === 'status') {
                    $validStatuses = ['active', 'inactive', 'schedule', 'draft', 'suspended', 'deleted'];
                    if (!in_array($value, $validStatuses)) {
                        echo json_encode(['success' => false, 'message' => __('Invalid status value')]);
                        return;
                    }
                }

                // Validate views (must be numeric)
                if ($field === 'views') {
                    if (!is_numeric($value)) {
                        echo json_encode(['success' => false, 'message' => __('Views must be a number')]);
                        return;
                    }
                    $updateData['views'] = (int)$value;
                }

                // Add updated_at timestamp
                $updateData['updated_at'] = date('Y-m-d H:i:s');

                // Update post using PostsModel
                $postModel = new PostsModel($posttype_slug, $post_lang);
                $tableName = posttype_name($posttype_slug, $post_lang);
                $result = $postModel->editPost($tableName, $postId, $updateData);

                if ($result) {
                    $response = [
                        'success' => true,
                        'message' => __('Post updated successfully')
                    ];

                    // Return new slug if title was updated
                    if ($field === 'title' && isset($updateData['slug'])) {
                        $response['data'] = ['slug' => $updateData['slug']];
                    }

                    echo json_encode($response);
                } else {
                    echo json_encode(['success' => false, 'message' => __('Failed to update post')]);
                }
            }
        } catch (\Exception $e) {
            echo json_encode([
                'success' => false,
                'message' => $e->getMessage()
            ]);
        }
    }

