    /**
     * Get term IDs by post ID
     * 
     * @param string $tableName Relationship table name
     * @param int $post_id Post ID
     * @return array
     */
    public function getTermsbyPostID($tableName, $post_id)
    {
        return DB::table($tableName)
            ->select(['rel_id'])
            ->where('post_id', $post_id)
            ->get();
    }

    /**
     * Get term IDs by post ID and language
     * 
     * @param string $tableName Relationship table name
     * @param int $post_id Post ID
     * @param string $lang Language code
     * @return array
     */
    public function getTermsbyPostIDAndLang($tableName, $post_id, $lang)
    {
        try {
            return DB::table($tableName)
                ->select(['rel_id'])
                ->where('post_id', $post_id)
                ->whereGroup(function($q) use ($lang) {
                    $q->where('lang', $lang)
                      ->orWhere('lang', 'all');
                })
                ->whereNotNull('rel_id')
                ->get();
        } catch (\Exception $e) {
            error_log("Error in PostsModel->getTermsbyPostIDAndLang: " . $e->getMessage());
            return [];
        }
    }

