     * @param string $tableName Table name
     * @param string $where WHERE clause
     * @param array $params Parameters
     * @return array|null
     */
    public function getRow($tableName, $where = '', $params = [])
    {
        $query = DB::table($tableName);
        
        if (!empty($where)) {
            // Parse WHERE clause
            $query->whereRaw($where, $params);
        }
        
        return $query->first();
