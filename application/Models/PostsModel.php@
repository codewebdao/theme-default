     */
    public function countPosts($where = '', $params = [])
    {
        if (empty($this->table)) {
            return 0;
        }
        
        $this->validateTable();
        
        $query = $this->newQuery();
        
        if (!empty($where)) {
            $query->whereRaw($where, $params);
        }
        
        return $query->count();
    }

    /**
     * Get post by ID with specific fields
     * 
     * @param int $id Post ID
     * @param string $fields Fields to select
     * @return array|null
     */
    public function getById($id, $fields = "*")
    {
        $this->validateTable();
        
        if ($fields === '*') {
            return $this->newQuery()->where('id', $id)->first();
        }
        
        $fieldsArray = array_map('trim', explode(',', $fields));
        return $this->newQuery()->select(...$fieldsArray)->where('id', $id)->first();
    }

    /**
     * Check unique field
     * 
     * @param string $field Field name
     * @param string $value Field value
     * @return bool true if unique, false if not unique
     */
    public function checkUniqueField($field, $value, $id = null)
    {
        $item =$this->newQuery()->where($field, $value)->first();
        if (!empty($item)){
            if ($item['id'] == $id){
                return true;
            }else{
                return false;
            }
        }
        return true;
    }

