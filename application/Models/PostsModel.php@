    /**
     * Delete reference relationship
     * 
     * @param string $tableName Relationship table name
     * @param int|null $post_id Post ID
     * @param string|null $postype_slug Post type slug
     * @param int|null $field_id Field ID
     * @param int|null $post_rel_id Related post ID
     * @param string|null $lang Language code
     * @return int Affected rows
     */
    public function deleteReferenceRelationship(
        $tableName,
        $post_id = null,
        $postype_slug = null,
        $field_id = null,
        $post_rel_id = null,
        $lang = null
    ) {
        $query = DB::table($tableName);
        
        // Add conditions dynamically
        if ($post_id !== null) {
            $query->where('post_id', $post_id);
        }
        
        if ($postype_slug !== null) {
            $query->where('postype_slug', $postype_slug);
        }
        
        if ($field_id !== null) {
            $query->where('field_id', $field_id);
        }
        
        if ($post_rel_id !== null) {
            $query->where('post_rel_id', $post_rel_id);
        }
        
        if ($lang !== null) {
            $query->where('lang', $lang);
        }
        
        return $query->delete();
    }

    /**
     * Get all post IDs by reference
     * 
     * @param string $tableName Relationship table name
     * @param string $postype_slug Post type slug
     * @param int $field_id Field ID
     * @param int $post_rel_id Related post ID
     * @param string|null $lang Language code
     * @param bool $allLang Include 'all' language
     * @return array
     */
    public function getAllPostIdByRenference($tableName, $postype_slug, $field_id, $post_rel_id, $lang = null, $allLang = true)
    {
        $query = DB::table($tableName)
            ->select(['post_id'])
            ->where('postype_slug', $postype_slug)
            ->where('field_id', $field_id)
            ->where('post_rel_id', $post_rel_id);
        
        if ($lang !== null) {
            if ($allLang) {
                $query->whereGroup(function($q) use ($lang) {
                    $q->where('lang', $lang)
                      ->orWhere('lang', 'all');
                });
            } else {
                $query->where('lang', $lang);
            }
        }
        
        return $query->pluck('post_id');
    }

