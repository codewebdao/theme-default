    /**
     * Duplicate post to multiple language tables
     * 
     * @param array $tablesName Target table names
     * @param string $oldTableName Source table name
     * @param int $id Post ID
     * @return mixed
     */
    public function duplicateLanguage($tablesName, $oldTableName, $id)
    {
        $sql = "START TRANSACTION;";

        foreach ($tablesName as $tableName) {
            $sql .= "    INSERT INTO $tableName \n";
            $sql .= "    SELECT * \n";
            $sql .= "    FROM $oldTableName \n";
            $sql .= "    WHERE id = $id; \n";
        }

        $sql .= "COMMIT;";
        return $this->raw($sql);
    }

